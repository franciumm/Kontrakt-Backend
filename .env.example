# ──────────────────────────────────────────────────────────────────────────
# Kontrakt environment variables. Copy this file to `.env` and fill in real
# values. NEVER commit a real `.env` and NEVER paste a real secret into this
# tracked example file — use placeholders only.
#
# Secrets handling (ticket SEC-103 follow-up):
#   In production, load FIREWORKS_API_KEY / JWT secrets from a secrets manager
#   (AWS Secrets Manager, GCP Secret Manager, or Vault) instead of a flat
#   .env file. The redaction filter in src/utils/logger.js strips any field
#   whose name matches /key|secret|password|token|auth/i before logging.
# ──────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# Fireworks AI — get from https://fireworks.ai/account/api-keys.
# Placeholder only. Real keys start with `fw_` and must NOT be committed.
FIREWORKS_API_KEY=fw_PLACEHOLDER_REPLACE_ME

# Optional — defaults to kimi-k2-instruct-0905. Per-service code hardcodes
# model IDs and ignores this var; it only affects the default in src/config.
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2-instruct-0905

# Auth (JWT) — generate strong random secrets for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-byte-hex-access-secret
JWT_REFRESH_SECRET=replace-with-64-byte-hex-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_SALT_ROUNDS=12

# MongoDB connection string. Use a local instance for dev.
MONGO_URI=mongodb+srv://yousefgamer9733_db_user:0000@cluster0.c1ywjpq.mongodb.net/?appName=Cluster0

# CORS — comma-separated origin allowlist. Empty = localhost dev default.
# Example: https://app.kontrakt.example.com,https://staging.kontrakt.example.com
CORS_ORIGINS=

# ──────────────────────────────────────────────────────────────────────────
# Hybrid model hosting (optional). gemma-4-26b-a4b-it and llama-v3p2-90b-vision
# are dedicated-only on Fireworks (no serverless tier). Split: gemma stays on a
# Fireworks dedicated deployment; vision runs on a self-hosted vLLM endpoint
# such as AMD Cloud for Developers.
# ──────────────────────────────────────────────────────────────────────────

# Fireworks dedicated deployment id for gemma-4-26b-a4b-it (fast-scan). After
# creating the deployment in the dashboard, paste its model id here. Empty
# falls back to the bare model id, which 404s until deployed.
GEMMA_MODEL=

# Self-hosted vLLM OpenAI-compatible endpoint for vision OCR (Llama-3.2-90B-
# Vision-Instruct), e.g. http://<instance>:8000/v1 . Empty = /extract unavailable.
AMD_BASE_URL=
AMD_API_KEY=
# Served-model name on the vLLM server. Default = HuggingFace repo id.
VISION_MODEL=
