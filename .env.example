# ──────────────────────────────────────────────────────────────────────────
# Kontrakt environment variables. Copy this file to `.env` and fill in real
# values. NEVER commit a real `.env` and NEVER paste a real secret into this
# tracked example file — use placeholders only.
#
# Secrets handling (ticket SEC-103 follow-up):
#   In production, load FIREWORKS_API_KEY / JWT secrets from a secrets manager
#   (AWS Secrets Manager, GCP Secret Manager, or Vault) instead of a flat
#   .env file. The redaction filter in src/utils/logger.js strips any field
#   whose name matches /key|secret|password|token|auth/i before logging.
# ──────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=production

# Set to 1 for multi-core cluster mode. Requires REDIS_URL — in-memory jobs
# do not work across workers. Leave unset for single-process deploy.
# CLUSTER=1

# Redis — optional for single instance; required for multi-replica / CLUSTER=1.
# Railway: add a Redis plugin and reference ${{Redis.REDIS_URL}}.
# REDIS_URL=redis://localhost:6379

# Fireworks AI — get from https://fireworks.ai/account/api-keys.
# Placeholder only. Real keys start with `fw_` and must NOT be committed.
FIREWORKS_API_KEY=fw_22CXxbKDAwaDSaeRQgEg6QLS

# Optional — defaults to kimi-k2-instruct-0905. Per-service code hardcodes
# model IDs and ignores this var; it only affects the default in src/config.
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2-instruct-0905

# Fireworks dedicated deployment for Gemma 4 31B IT.
# Used by: fast-scan (audit.service.js) and vision OCR (vision.service.js).
# After creating the deployment in the dashboard, paste its deployment ID here.
GEMMA_MODEL=accounts/francium/deployments/qi296nit

# Auth (JWT) — generate strong random secrets for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-byte-hex-access-secret213jklmwa
JWT_REFRESH_SECRET=replace-with-64-byte-hex-refresh-secrew1kjlmkwdt
JWT_EXTRACT_SECRET=replace-with-64-byte-hex-extract-secawdkjm12k mret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_EXTRACT_TTL=15m
JWT_SALT_ROUNDS=12

# MongoDB connection string. Use a local instance for dev.
MONGO_URI=mongodb://localhost:27017/kontrakt

# CORS — comma-separated origin allowlist. Empty = localhost dev default.
# Example: https://app.kontrakt.example.com,https://staging.kontrakt.example.com
CORS_ORIGINS=

# ──────────────────────────────────────────────────────────────────────────
# AMD Cloud — Injection Classifier ONLY
# Vision OCR has been moved to Fireworks (GEMMA_MODEL above).
# The AMD provider now only serves the Layer 5 injection classifier at :8001.
# ──────────────────────────────────────────────────────────────────────────
AMD_CLASSIFIER_BASE_URL=http://36.150.116.194:8001/v1
AMD_CLASSIFIER_API_KEY=http://36.150.116.194:8001/v1
CLASSIFIER_MODEL=Qwen/Qwen2.5-7B-Instruct
